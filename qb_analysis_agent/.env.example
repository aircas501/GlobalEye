# ===========================================
# QB Analysis Agent — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# ----- LLM Configuration -----
LLM_BASE_URL="https://api.deepseek.com"
LLM_MODEL="deepseek-chat"
LLM_API_KEY=sk-your-api-key-here

# ----- Embedding Configuration -----
EMBEDDING_API_KEY=sk-your-embedding-api-key-here
EMBEDDING_MODEL=text-embedding-v4

# ----- Rerank Configuration -----
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
RERANK_MODEL=qwen3-rerank
RERANK_API_KEY=sk-your-rerank-api-key-here

# ----- Milvus Vector Database -----
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=your-milvus-password-here
MILVUS_ALIAS=default
MILVUS_COLLECTION_NAME=your-milvus-collection-name-here

# ----- Redis (Meeting State) -----
MEET_REDIS_HOST=localhost
MEET_REDIS_PORT=6379
MEET_REDIS_PASSWORD=your-redis-password-here
MEET_REDIS_DB=0

# ----- Neo4j Graph Database -----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# ----- MinIO Object Storage -----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# ----- Server Configuration -----
API_PORT=9000
API_HOST=0.0.0.0
SSE_PORT=9092
SSE_HOST=0.0.0.0

# ----- CORS -----
CORS_ORIGINS=*

# ----- Skill API -----
SKILL_API_HOST=your-skill-api-host

# ----- LightRAG API -----
LIGHTRAG_HOST_PORT=http://your-lightrag-host:port
